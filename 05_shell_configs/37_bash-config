# Función maestra Git
function useGit() {
  local accion="$1"
  local arg="$2"

  if [[ -z "$accion" ]]; then
    git status
    return
  fi

  case "$accion" in
    commit-up)
      git add . && git commit -m "$arg" && git push
      ;;
    commit-sign)
      git add . && git commit -S -m "$arg" && git push
      ;;
    fix)
      git add . && git commit --amend --no-edit && git push --force-with-lease
      ;;
    update)
      git pull && git status
      ;;
    view)
      git status && git log --oneline --decorate --all -n 5
      ;;
    undo)
      git reset HEAD~1 && git status
      ;;
    *)
      git "$@"
      ;;
  esac
}

# Función Verificar Hash
function useVerify() {
    local file="$HOME/Descargas/$1"
    local user_input="${2:-}"
    local user_algo="${3:-}"

    if [ ! -f "$file" ]; then
        echo "❌ Error: El archivo '$1' no existe en ~/Descargas"
        return 1
    fi

    local algo="sha256"
    local compare_hash=""

    case "$user_input" in
        sha1|sha256|sha512|md5)
            algo="$user_input"
            ;;
        *)
            compare_hash="$user_input"
            ;;
    esac

    if [ -n "$user_algo" ]; then
        algo="$user_algo"
    fi

    local cmd
    case "$algo" in
        sha1)   cmd="sha1sum" ;;
        sha256) cmd="sha256sum" ;;
        sha512) cmd="sha512sum" ;;
        md5)    cmd="md5sum" ;;
        *)      echo "⚠️ Algoritmo no soportado: $algo"; return 1 ;;
    esac

    local calculated
    calculated=$($cmd "$file" | awk '{print $1}')

    if [ -n "$compare_hash" ]; then
        if [ "$calculated" = "$compare_hash" ]; then
            echo "✅ VERIFICACIÓN EXITOSA ($algo)"
        else
            echo "❌ ERROR: Los hashes NO coinciden ($algo)"
            echo "Esperado:  $compare_hash"
            echo "Calculado: $calculated"
        fi
    else
        echo "🔎 Archivo: $file"
        echo "Algoritmo:  $algo"
        echo "Hash:       $calculated"
    fi
}

# Función Generador de Contraseñas
function usePWGEN() {
    local cantidad=${1:-1}
    
    if [[ ! "$cantidad" =~ ^[0-9]+$ ]] || [[ "$cantidad" -lt 1 ]]; then
        echo "Uso: usePWGEN [cantidad]"
        return 1
    fi

    local count=0
    while (( count < cantidad )); do
        local num=$(printf "%04d" $((RANDOM % 10000)))
        local let=$(LC_ALL=C tr -dc 'A-Z' </dev/urandom | head -c 3)
        echo "${num} ${let}"
        ((count++))
    done
}

# Función Descarga Media (yt-dlp)
function useMediaDownload() {
    local url=""
    local carpeta=""
    local args=()
    local cookie_file="$HOME/.config/yt-dlp/cookies.txt"

    if ! command -v yt-dlp &>/dev/null; then
        echo "❌ Error: 'yt-dlp' no está instalado."
        return 1
    fi

    local modo="video_local"

    if [[ "$1" =~ ^- ]]; then
        modo="$1"
        shift
    fi

    if [[ -z "$1" ]]; then
        echo "Uso: media [opcion] [url] [carpeta_destino]"
        return 1
    fi
    
    url="$1"
    if [[ -n "$2" ]]; then carpeta="$2"; fi

    case "$modo" in
        -m|--music)
            if [[ -z "$carpeta" ]]; then carpeta="$HOME/Música"; fi
            args+=(-x --audio-format mp3 --audio-quality 0 --embed-thumbnail --add-metadata)
            echo "🎵 Modo: Música (MP3)"
            ;;
        -v|--video)
            if [[ -z "$carpeta" ]]; then carpeta="$HOME/Videos"; fi
            args+=(--merge-output-format mp4 --embed-thumbnail --add-metadata)
            echo "🎬 Modo: Video"
            ;;
        *)
            if [[ -z "$carpeta" ]]; then carpeta="$(pwd)"; fi
            args+=(--merge-output-format mp4)
            echo "📁 Modo: Video (Carpeta actual)"
            ;;
    esac

    mkdir -p "$carpeta"
    echo "📂 Destino: $carpeta"
    echo "⏳ Actualizando yt-dlp..."
    yt-dlp -U &>/dev/null

    local cmd="yt-dlp ${args[*]} -o \"$carpeta/%(title)s.%(ext)s\" \"$url\""
    eval "$cmd"
}

